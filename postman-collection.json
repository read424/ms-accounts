{
  "info": {
    "_postman_id": "banking-platform-part2",
    "name": "Banking Platform - Parte II (VIP/PYME + Balance)",
    "description": "Colección de pruebas para validar microservicios ms-accounts (con perfiles VIP/PYME), ms-balance y reportes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "MS-Accounts Estándar",
      "item": [
        {
          "name": "1. Personal - SAVINGS Estándar",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"customerId\": \"PERSONAL_001\",\n  \"accountType\": \"SAVINGS\",\n  \"initialBalance\": 2000.00,\n  \"profileType\": \"STANDARD\"\n}"},
            "url": {"raw": "{{ms-accounts-url}}/api/v1/accounts", "host": ["{{ms-accounts-url}}"], "path": ["api", "v1", "accounts"]}
          }
        },
        {
          "name": "2. Personal - CURRENT Estándar",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"customerId\": \"PERSONAL_002\",\n  \"accountType\": \"CURRENT\",\n  \"initialBalance\": 5000.00,\n  \"profileType\": \"STANDARD\"\n}"},
            "url": {"raw": "{{ms-accounts-url}}/api/v1/accounts", "host": ["{{ms-accounts-url}}"], "path": ["api", "v1", "accounts"]}
          }
        },
        {
          "name": "3. Business - CURRENT Estándar",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"customerId\": \"BUSINESS_001\",\n  \"accountType\": \"CURRENT\",\n  \"initialBalance\": 50000.00,\n  \"profileType\": \"STANDARD\",\n  \"accountHolders\": [{\"customerId\": \"BUSINESS_001\"}]\n}"},
            "url": {"raw": "{{ms-accounts-url}}/api/v1/accounts", "host": ["{{ms-accounts-url}}"], "path": ["api", "v1", "accounts"]}
          }
        }
      ]
    },
    {
      "name": "MS-Accounts PARTE II - Nuevos Perfiles",
      "item": [
        {
          "name": "4. Personal VIP - SAVINGS (Mín $10,000)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function() {pm.response.to.have.status(201);});",
                  "pm.test('Profile es VIP', function() {var jsonData = pm.response.json(); pm.expect(jsonData.profileType).to.equal('VIP');});",
                  "pm.test('Max monthly transactions es 50', function() {var jsonData = pm.response.json(); pm.expect(jsonData.maxMonthlyTransactionsNoFee).to.equal(50);});",
                  "pm.test('Minimum daily balance es $10,000', function() {var jsonData = pm.response.json(); pm.expect(jsonData.minimumDailyBalance).to.equal(10000);});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"customerId\": \"PERSONAL_VIP_001\",\n  \"accountType\": \"SAVINGS\",\n  \"initialBalance\": 15000.00,\n  \"profileType\": \"VIP\"\n}"},
            "url": {"raw": "{{ms-accounts-url}}/api/v1/accounts", "host": ["{{ms-accounts-url}}"], "path": ["api", "v1", "accounts"]}
          }
        },
        {
          "name": "5. Personal VIP - VALIDACIÓN: Balance insuficiente (<$10,000)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400 Bad Request', function() {pm.response.to.have.status(400);});",
                  "pm.test('Error message menciona mínimo requerido', function() {var jsonData = pm.response.json(); pm.expect(jsonData.message).to.include('minimum');});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"customerId\": \"PERSONAL_VIP_INVALID\",\n  \"accountType\": \"SAVINGS\",\n  \"initialBalance\": 5000.00,\n  \"profileType\": \"VIP\"\n}"},
            "url": {"raw": "{{ms-accounts-url}}/api/v1/accounts", "host": ["{{ms-accounts-url}}"], "path": ["api", "v1", "accounts"]}
          }
        },
        {
          "name": "6. Business PYME - CURRENT sin comisión",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function() {pm.response.to.have.status(201);});",
                  "pm.test('Profile es PYME', function() {var jsonData = pm.response.json(); pm.expect(jsonData.profileType).to.equal('PYME');});",
                  "pm.test('Maintenance fee es $0', function() {var jsonData = pm.response.json(); pm.expect(jsonData.maintenanceFee).to.equal(0);});",
                  "pm.test('Max monthly transactions es 300', function() {var jsonData = pm.response.json(); pm.expect(jsonData.maxMonthlyTransactionsNoFee).to.equal(300);});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"customerId\": \"BUSINESS_PYME_001\",\n  \"accountType\": \"CURRENT\",\n  \"initialBalance\": 25000.00,\n  \"profileType\": \"PYME\",\n  \"accountHolders\": [{\"customerId\": \"BUSINESS_PYME_001\"}]\n}"},
            "url": {"raw": "{{ms-accounts-url}}/api/v1/accounts", "host": ["{{ms-accounts-url}}"], "path": ["api", "v1", "accounts"]}
          }
        },
        {
          "name": "7. Business PYME - VALIDACIÓN: No SAVINGS",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 400 Bad Request', function() {pm.response.to.have.status(400);});",
                  "pm.test('Error menciona CHECKING requirement', function() {var jsonData = pm.response.json(); pm.expect(jsonData.message).to.include('CHECKING');});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\n  \"customerId\": \"BUSINESS_PYME_INVALID\",\n  \"accountType\": \"SAVINGS\",\n  \"initialBalance\": 20000.00,\n  \"profileType\": \"PYME\",\n  \"accountHolders\": [{\"customerId\": \"BUSINESS_PYME_INVALID\"}]\n}"},
            "url": {"raw": "{{ms-accounts-url}}/api/v1/accounts", "host": ["{{ms-accounts-url}}"], "path": ["api", "v1", "accounts"]}
          }
        }
      ]
    },
    {
      "name": "MS-Balance - Reportes",
      "item": [
        {
          "name": "8. Get Balance - Por Product ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function() {pm.response.to.have.status(200);});",
                  "pm.test('Response tiene productId, currentBalance', function() {var jsonData = pm.response.json(); pm.expect(jsonData).to.have.property('productId'); pm.expect(jsonData).to.have.property('currentBalance');});",
                  "pm.test('Response tiene productType', function() {var jsonData = pm.response.json(); pm.expect(['ACCOUNT','CREDIT']).to.include(jsonData.productType);});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{ms-balance-url}}/balances/ACC-0001001", "host": ["{{ms-balance-url}}"], "path": ["balances", "ACC-0001001"]}
          }
        },
        {
          "name": "9. Get All Balances - Por Customer ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function() {pm.response.to.have.status(200);});",
                  "pm.test('Response es Flux de BalanceResponse', function() {var jsonData = pm.response.json(); pm.expect(jsonData).to.be.an('array');});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{ms-balance-url}}/balances/customer/CUST-123", "host": ["{{ms-balance-url}}"], "path": ["balances", "customer", "CUST-123"]}
          }
        },
        {
          "name": "10. Últimos 10 Movimientos - Tarjeta",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function() {pm.response.to.have.status(200);});",
                  "pm.test('Response es array de transacciones', function() {var jsonData = pm.response.json(); pm.expect(jsonData).to.be.an('array');});",
                  "pm.test('Máximo 10 movimientos', function() {var jsonData = pm.response.json(); pm.expect(jsonData.length).to.be.lessThanOrEqual(10);});",
                  "pm.test('Cada transacción tiene type, amount, timestamp', function() {var jsonData = pm.response.json(); jsonData.forEach(function(t) {pm.expect(t).to.have.property('type'); pm.expect(t).to.have.property('amount'); pm.expect(t).to.have.property('timestamp');});});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{ms-balance-url}}/reports/transactions/latest?productId=ACC-0001001&limit=10",
              "host": ["{{ms-balance-url}}"],
              "path": ["reports", "transactions", "latest"],
              "query": [{"key": "productId", "value": "ACC-0001001"}, {"key": "limit", "value": "10"}]
            }
          }
        },
        {
          "name": "11. Reporte General - Intervalo de Tiempo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function() {pm.response.to.have.status(200);});",
                  "pm.test('Response tiene startDate, endDate, totalTransactions', function() {var jsonData = pm.response.json(); pm.expect(jsonData).to.have.property('startDate'); pm.expect(jsonData).to.have.property('endDate'); pm.expect(jsonData).to.have.property('totalTransactions');});",
                  "pm.test('Response tiene statistics (deposits, withdrawals, etc)', function() {var jsonData = pm.response.json(); pm.expect(jsonData).to.have.property('totalDeposits'); pm.expect(jsonData).to.have.property('totalAmount');});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{ms-balance-url}}/reports/general?startDate=2024-01-01&endDate=2024-12-31&productId=ACC-0001001",
              "host": ["{{ms-balance-url}}"],
              "path": ["reports", "general"],
              "query": [{"key": "startDate", "value": "2024-01-01"}, {"key": "endDate", "value": "2024-12-31"}, {"key": "productId", "value": "ACC-0001001"}]
            }
          }
        },
        {
          "name": "12. Reporte General - Todos los Productos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200 OK', function() {pm.response.to.have.status(200);});",
                  "pm.test('Sin productId incluye todos', function() {var jsonData = pm.response.json(); pm.expect(jsonData.productId).to.be.null;});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{ms-balance-url}}/reports/general?startDate=2024-01-01&endDate=2024-12-31",
              "host": ["{{ms-balance-url}}"],
              "path": ["reports", "general"],
              "query": [{"key": "startDate", "value": "2024-01-01"}, {"key": "endDate", "value": "2024-12-31"}]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {"key": "ms-accounts-url", "value": "http://localhost:8082", "type": "string"},
    {"key": "ms-credits-url", "value": "http://localhost:8083", "type": "string"},
    {"key": "ms-transaction-url", "value": "http://localhost:8084", "type": "string"},
    {"key": "ms-balance-url", "value": "http://localhost:8085", "type": "string"},
    {"key": "customer-id", "value": "CUST-123", "type": "string"}
  ]
}
