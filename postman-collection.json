  "item": [
    {
      "name": "1. Personal Customer - Crear Cuenta SAVINGS",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201 Created', function() {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Response has accountId', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData).to.have.property('accountId');",
              "  pm.globals.set('personalAccountSavingsId', jsonData.accountId);",
              "});",
              "",
              "pm.test('Account type is SAVINGS', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData.accountType).to.equal('SAVINGS');",
              "});",
              "",
              "pm.test('Initial balance is correct', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData.balance).to.equal(2000);",
              "});",
              "",
              "pm.test('Status is ACTIVE', function() {",
              "  var jsonData = pm.response.json();",
              "  pm.expect(jsonData.status).to.equal('ACTIVE');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"customerId\": \"PERSONAL_001\",\n  \"accountType\": \"SAVINGS\",\n  \"initialBalance\": 2000.00,\n  \"monthlyTransactionLimit\": 5\n}"
        },
        "url": {
